menu "Cikon IoT Board Configuration"
    config BOARD_STATUS_LED_GPIO
        int "Status LED GPIO"
        default 2
        range 0 39
        help
            GPIO number for the status LED. Set to -1 to disable.
            Indicates device status (booting, WiFi connection, errors, etc.)
    config VFS_EVENTFD_MAX_FDS
        int "Max eventfd file descriptors (0 = disabled)"
        default 0
        range 0 16
        help
            Register esp_vfs_eventfd at platform init with this many fds.
            Set > 0 when using OpenThread (needs ~4: netif, task queue,
            border router, spinel). Can only be registered once globally.

    config VFS_LITTLEFS_ENABLED
        bool "Mount LittleFS partition at boot"
        default n

    config VFS_LITTLEFS_MOUNT_POINT
        string "Mount point"
        default "/data"
        depends on VFS_LITTLEFS_ENABLED

    config VFS_LITTLEFS_PARTITION
        string "Partition label"
        default "littlefs"
        depends on VFS_LITTLEFS_ENABLED

    config VFS_SPIFFS_ENABLED
        bool "Mount SPIFFS partition at boot"
        default n

    config VFS_SPIFFS_MOUNT_POINT
        string "Mount point"
        default "/spiffs"
        depends on VFS_SPIFFS_ENABLED

    config VFS_SPIFFS_PARTITION
        string "Partition label"
        default "web_storage"
        depends on VFS_SPIFFS_ENABLED

endmenu