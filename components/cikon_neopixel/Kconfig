menu "Cikon IoT NeoPixel Configuration"

    config NEOPIXEL_GPIO_PIN
        int "NeoPixel GPIO Pin"
        default 35
        help
            GPIO pin connected to the NeoPixel data line.

    config NEOPIXEL_LED_COUNT
        int "Number of LEDs"
        default 1
        range 1 1024
        help
            Total number of LEDs in the strip.

    config NEOPIXEL_DEFAULT_BRIGHTNESS
        int "Default brightness (0-255)"
        default 128
        range 0 255
        help
            Initial brightness applied to all pixels.

    config NEOPIXEL_EFFECTS_TASK_STACK_SIZE
        int "Effects task stack size (bytes)"
        default 3072
        range 2048 8192
        help
            Stack size for the FreeRTOS task running LED effects.
            Increase if effects crash or show stack overflow.
            Rainbow effect requires ~3KB due to HSV conversion and semaphore operations.

    config NEOPIXEL_EFFECTS_TASK_PRIORITY
        int "Effects task priority"
        default 5
        range 1 24
        help
            FreeRTOS priority for the effects task.
            Higher values = higher priority (max 24).

endmenu
