menu "Thread Border Router Adapter"

    config THREAD_BORDER_ROUTER_NETWORK_NAME
        string "Thread network name"
        default "cikon-thread"

    config THREAD_BORDER_ROUTER_CHANNEL
        int "Thread channel (11-26, avoid WiFi ch 1/6/11 overlap)"
        default 15
        range 11 26

    config THREAD_BORDER_ROUTER_WAKEUP_CHANNEL
        int "Wake-up channel for CSL sleepy devices (0 = same as main channel)"
        default 25
        range 0 26

    config THREAD_BORDER_ROUTER_PROVISIONED_DATASET
        string "Provisioned dataset hex (from 'ot dataset active -x', empty = generate new)"
        default ""
        help
            Full dataset backup. Used when NVS is empty (e.g. after controller swap).
            Get value by running: ot dataset active -x

endmenu
