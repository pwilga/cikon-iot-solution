menu "cikon_http"

    config HTTP_PORT
        int "HTTP server port"
        default 8080
        range 1 65535

    config HTTP_ENABLE_WEBDAV
        bool "Enable WebDAV server at /dav/"
        default y
        help
            Registers WebDAV handlers (OPTIONS, PROPFIND, GET, PUT, DELETE,
            MKCOL, MOVE, LOCK, UNLOCK) at the /dav/ prefix. Works over WiFi
            and Thread/IPv6. Compatible with cadaver, curl, rclone, macOS Finder.

    config HTTP_STACK_SIZE
        int "HTTP server task stack size (bytes)"
        default 7168 if HTTP_ENABLE_WEBDAV
        default 5120

    config HTTP_MAX_HANDLERS
        int "Maximum URI handlers"
        default 24 if HTTP_ENABLE_WEBDAV
        default 16
        range 4 64

    config HTTP_CTRL_PORT
        int "HTTP server internal ctrl socket port"
        default 32769
        range 1024 65535

    config HTTP_MAX_OPEN_SOCKETS
        int "Maximum open sockets"
        default 4
        range 1 16

    config HTTP_SESSION_TIMEOUT
        int "Keep-Alive idle timeout (seconds)"
        default 10
        range 2 120
        help
            Sent to the browser as "Keep-Alive: timeout=N". Overrides the browser's
            default (~90 s), causing it to close idle connections sooner and free the
            ~25 KB mbedTLS session buffer. Must be longer than the polling interval
            so active connections are not torn down prematurely.

    config HTTPS_STACK_SIZE
        int "HTTPS server task stack size (bytes)"
        default 10240

    config HTTPS_PORT
        int "HTTPS server port"
        default 443
        range 1 65535

    config HTTPS_CTRL_PORT
        int "HTTPS server internal ctrl socket port"
        default 32769
        range 1024 65535

    config HTTPS_MAX_OPEN_SOCKETS
        int "Maximum open sockets (HTTPS)"
        default 4
        range 1 16

endmenu
